// DiagConnect — Prisma Schema
// Run: npx prisma generate
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANTS (Diagnostic Centers) ────────────────────────────────────────────
model Tenant {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  plan           Plan      @default(BASIC)
  planExpiresAt  DateTime?
  ownerName      String
  email          String
  phone          String
  whatsappNumber String?
  wabaPhoneId    String?
  wabaToken      String?
  address        String?
  city           String    @default("Navi Mumbai")
  pincode        String?
  openTime       String    @default("08:00")
  closeTime      String    @default("20:00")
  isActive       Boolean   @default(true)
  kycStatus      String    @default("pending")
  razorpayKeyId  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  users         User[]
  patients      Patient[]
  appointments  Appointment[]
  reports       Report[]
  tests         Test[]
  campaigns     Campaign[]
  auditLogs     AuditLog[]
  slotOverrides SlotOverride[]

  @@map("tenants")
}

// ─── USERS ────────────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  name         String
  role         UserRole @default(STAFF)
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@map("users")
}

// ─── PATIENTS ─────────────────────────────────────────────────────────────────
model Patient {
  id             String    @id @default(cuid())
  tenantId       String
  name           String
  phone          String
  email          String?
  dob            DateTime?
  gender         String?
  area           String?
  bloodGroup     String?
  notes          String?
  tags           String[]  @default([])
  isActive       Boolean   @default(true)
  whatsappOptIn  Boolean   @default(false)
  marketingOptIn Boolean   @default(false)
  consentGivenAt DateTime?
  lastVisitAt    DateTime?
  totalVisits    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  reports      Report[]

  @@unique([tenantId, phone])
  @@map("patients")
}

// ─── TESTS (Master Catalog) ───────────────────────────────────────────────────
model Test {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  name        String
  category    String?
  price       Decimal  @db.Decimal(10, 2)
  sampleType  String?
  preparation String?
  tatHours    Int      @default(6)
  isPopular   Boolean  @default(false)
  isPackage   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@unique([tenantId, code])
  @@map("tests")
}

// ─── APPOINTMENTS ─────────────────────────────────────────────────────────────
model Appointment {
  id              String            @id @default(cuid())
  tenantId        String
  patientId       String
  testId          String?
  testName        String
  testCode        String?
  testPrice       Decimal           @db.Decimal(10, 2)
  scheduledDate   DateTime
  slot            String
  status          AppointmentStatus @default(PENDING)
  bookingSource   BookingSource     @default(WALKIN)
  referenceNo     String            @unique
  patientPhone    String
  patientName     String
  notes           String?
  prep            String?
  reminderSent24h Boolean           @default(false)
  reminderSent2h  Boolean           @default(false)
  paymentStatus   String            @default("pending")
  paymentId       String?
  paymentAmount   Decimal?          @db.Decimal(10, 2)
  cancelReason    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id])
  test    Test?   @relation(fields: [testId], references: [id])
  report  Report?

  @@map("appointments")
}

// ─── REPORTS ──────────────────────────────────────────────────────────────────
model Report {
  id             String         @id @default(cuid())
  tenantId       String
  patientId      String
  appointmentId  String         @unique
  fileName       String
  fileKey        String
  fileChecksum   String?
  uploadedAt     DateTime       @default(now())
  deliveredAt    DateTime?
  deliveryStatus DeliveryStatus @default(PENDING)
  waMessageId    String?
  readAt         DateTime?
  autoDelivered  Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  patient     Patient     @relation(fields: [patientId], references: [id])
  appointment Appointment @relation(fields: [appointmentId], references: [id])

  @@map("reports")
}

// ─── SLOT OVERRIDES ───────────────────────────────────────────────────────────
model SlotOverride {
  id        String   @id @default(cuid())
  tenantId  String
  date      DateTime
  slot      String
  capacity  Int      @default(3)
  createdBy String?
  updatedBy String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, date, slot], name: "tenantId_date_slot")
  @@map("slot_overrides")
}

// ─── CAMPAIGNS ────────────────────────────────────────────────────────────────
model Campaign {
  id           String    @id @default(cuid())
  tenantId     String
  name         String
  type         String
  status       String    @default("draft")
  message      String
  templateName String?
  scheduledAt  DateTime?
  sentAt       DateTime?
  totalSent    Int       @default(0)
  totalOpened  Int       @default(0)
  totalBooked  Int       @default(0)
  revenue      Decimal   @default(0) @db.Decimal(10, 2)
  createdAt    DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("campaigns")
}

// ─── AUDIT LOGS ───────────────────────────────────────────────────────────────
model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  timestamp  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────
enum Plan {
  BASIC
  PREMIUM
  PRO
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
  LAB
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  ARRIVED
  SAMPLE_COLLECTED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  WHATSAPP_BOT
  WALKIN
  PHONE
  API
  WEBSITE
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}
